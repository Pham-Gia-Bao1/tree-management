{
  "token": {
    "colorPrimary": "#7C3AED",
    "colorSuccess": "#22C55E",
    "colorWarning": "#F59E0B",
    "colorError": "#EF4444",
    "colorInfo": "#3B82F6",

    "colorText": "#111827",
    "colorTextSecondary": "#6B7280",
    "colorTextTertiary": "#9CA3AF",

    "colorBgBase": "#FCFCFE",
    "colorBgLayout": "#F7F8FC",
    "colorBgContainer": "#FFFFFF",
    "colorBgElevated": "#FFFFFF",

    "colorBorder": "#E7E8F2",
    "colorBorderSecondary": "#F2F4F8",

    "borderRadius": 10,
    "borderRadiusSM": 8,
    "borderRadiusLG": 16,
    "borderRadiusXS": 6,

    "fontFamily": "\"Inter\", sans-serif",
    "fontSize": 14,

    "controlHeight": 44,
    "controlHeightSM": 36,
    "controlHeightLG": 48,

    "boxShadow": "0 1px 2px rgba(15,23,42,.04),0 8px 24px rgba(15,23,42,.04)",
    "boxShadowSecondary": "0 8px 30px rgba(15,23,42,.06)",
    "boxShadowTertiary": "0 2px 6px rgba(15,23,42,.03)"
  },

  "components": {
    "Layout": {
      "bodyBg": "#F7F8FC",
      "headerBg": "#FFFFFF",
      "siderBg": "#FFFFFF"
    },

    "Card": {
      "borderRadiusLG": 16,
      "bodyPadding": 24,
      "headerPadding": 24
    },

    "Button": {
      "borderRadius": 10,
      "controlHeight": 44,

      "fontWeight": 600,

      "defaultBorderColor": "#E7E8F2",
      "defaultHoverBorderColor": "#CFC5F9",

      "defaultShadow": "none",
      "primaryShadow": "none",

      "colorPrimary": "#7C3AED",
      "colorPrimaryHover": "#8B5CF6",
      "colorPrimaryActive": "#6D28D9"
    },

    "Input": {
      "borderRadius": 10,
      "controlHeight": 44,

      "paddingInline": 14,

      "hoverBorderColor": "#A78BFA",
      "activeBorderColor": "#7C3AED",
      "activeShadow": "0 0 0 4px rgba(124,58,237,.10)"
    },

    "InputNumber": {
      "borderRadius": 10,
      "controlHeight": 44,
      "activeBorderColor": "#7C3AED"
    },

    "Select": {
      "borderRadius": 10,
      "controlHeight": 44,

      "optionHeight": 40,

      "optionSelectedBg": "#F3E8FF",
      "optionActiveBg": "#FAF5FF",

      "hoverBorderColor": "#A78BFA",
      "activeBorderColor": "#7C3AED"
    },

    "DatePicker": {
      "borderRadius": 10,
      "controlHeight": 44,
      "activeBorderColor": "#7C3AED"
    },

    "TimePicker": {
      "borderRadius": 10,
      "controlHeight": 44,
      "activeBorderColor": "#7C3AED"
    },

    "Table": {
      "borderRadiusLG": 16,

      "headerBg": "#FAFBFD",
      "headerColor": "#374151",

      "rowHoverBg": "#FAF7FF",

      "borderColor": "#ECEEF5",

      "cellPaddingBlock": 16,
      "cellPaddingInline": 20
    },

    "Menu": {
      "itemHeight": 44,

      "itemBorderRadius": 10,

      "itemColor": "#6B7280",

      "itemHoverBg": "#F8F5FF",
      "itemHoverColor": "#7C3AED",

      "itemSelectedBg": "#F3E8FF",
      "itemSelectedColor": "#6D28D9"
    },

    "Tabs": {
      "itemColor": "#6B7280",
      "itemHoverColor": "#7C3AED",
      "itemSelectedColor": "#7C3AED",

      "inkBarColor": "#7C3AED",

      "horizontalItemPadding": "12px 0"
    },

    "Modal": {
      "borderRadiusLG": 18
    },

    "Drawer": {
      "borderRadiusLG": 18
    },

    "Dropdown": {
      "borderRadiusLG": 14
    },

    "Popover": {
      "borderRadiusLG": 14
    },

    "Tooltip": {
      "borderRadius": 8
    },

    "Pagination": {
      "borderRadius": 10
    },

    "Collapse": {
      "borderRadiusLG": 14
    },

    "Segmented": {
      "trackBg": "#F3F4F8",

      "itemSelectedBg": "#FFFFFF"
    },

    "Tag": {
      "borderRadiusSM": 999
    },

    "Checkbox": {
      "colorPrimary": "#7C3AED"
    },

    "Radio": {
      "colorPrimary": "#7C3AED"
    },

    "Switch": {
      "colorPrimary": "#7C3AED"
    },

    "Divider": {
      "colorSplit": "#ECEEF5"
    },

    "Descriptions": {
      "labelBg": "#FAFBFD"
    },

    "List": {
      "colorBorder": "#ECEEF5"
    }
  }
}
