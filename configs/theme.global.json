{
  "token": {
    "colorPrimary": "#18B7C9",
    "colorSuccess": "#22C55E",
    "colorWarning": "#F59E0B",
    "colorError": "#EF4444",
    "colorInfo": "#18B7C9",

    "colorText": "#2F3A45",
    "colorTextSecondary": "#64748B",
    "colorTextTertiary": "#94A3B8",

    "colorBgBase": "#F7F9FB",
    "colorBgLayout": "#F4F7FA",
    "colorBgContainer": "#FFFFFF",
    "colorBgElevated": "#FFFFFF",

    "colorBorder": "#DCE5EC",
    "colorBorderSecondary": "#EDF2F7",

    "borderRadius": 8,
    "borderRadiusSM": 6,
    "borderRadiusLG": 12,
    "borderRadiusXS": 4,

    "fontFamily": "\"Inter\", sans-serif",
    "fontSize": 14,

    "controlHeight": 40,
    "controlHeightSM": 34,
    "controlHeightLG": 44,

    "boxShadow": "0 1px 2px rgba(15,23,42,.04)",
    "boxShadowSecondary": "0 4px 12px rgba(15,23,42,.05)",
    "boxShadowTertiary": "none"
  },

  "components": {
    "Layout": {
      "bodyBg": "#F4F7FA",
      "headerBg": "#FFFFFF",
      "siderBg": "#FFFFFF"
    },

    "Card": {
      "borderRadiusLG": 10,
      "bodyPadding": 20,
      "headerPadding": 20
    },

    "Button": {
      "borderRadius": 6,
      "controlHeight": 36,

      "fontWeight": 500,

      "defaultBorderColor": "#D7E2EA",
      "defaultHoverBorderColor": "#18B7C9",

      "defaultShadow": "none",
      "primaryShadow": "none",

      "colorPrimary": "#18B7C9",
      "colorPrimaryHover": "#22C7D9",
      "colorPrimaryActive": "#1096A5"
    },

    "Input": {
      "borderRadius": 6,
      "controlHeight": 38,

      "paddingInline": 12,

      "hoverBorderColor": "#59D2DE",
      "activeBorderColor": "#18B7C9",
      "activeShadow": "0 0 0 3px rgba(24,183,201,.15)"
    },

    "InputNumber": {
      "borderRadius": 6,
      "controlHeight": 38,
      "activeBorderColor": "#18B7C9"
    },

    "Select": {
      "borderRadius": 6,
      "controlHeight": 38,

      "optionHeight": 36,

      "optionSelectedBg": "#EAFBFD",
      "optionActiveBg": "#F5FEFF",

      "hoverBorderColor": "#59D2DE",
      "activeBorderColor": "#18B7C9"
    },

    "DatePicker": {
      "borderRadius": 6,
      "controlHeight": 38,
      "activeBorderColor": "#18B7C9"
    },

    "TimePicker": {
      "borderRadius": 6,
      "controlHeight": 38,
      "activeBorderColor": "#18B7C9"
    },

    "Table": {
      "borderRadiusLG": 10,

      "headerBg": "#F8FAFC",
      "headerColor": "#475569",

      "rowHoverBg": "#F4FCFD",
      "rowSelectedBg": "#EAFBFD",

      "borderColor": "#E2E8F0",

      "cellPaddingBlock": 14,
      "cellPaddingInline": 16
    },

    "Menu": {
      "itemHeight": 40,

      "itemBorderRadius": 6,

      "itemColor": "#64748B",

      "itemHoverBg": "#F1FCFD",
      "itemHoverColor": "#18B7C9",

      "itemSelectedBg": "#EAFBFD",
      "itemSelectedColor": "#1096A5"
    },

    "Tabs": {
      "itemColor": "#64748B",
      "itemHoverColor": "#18B7C9",
      "itemSelectedColor": "#18B7C9",

      "inkBarColor": "#18B7C9",

      "horizontalItemPadding": "10px 0"
    },

    "Modal": {
      "borderRadiusLG": 10
    },

    "Drawer": {
      "borderRadiusLG": 10
    },

    "Dropdown": {
      "borderRadiusLG": 8
    },

    "Popover": {
      "borderRadiusLG": 8
    },

    "Tooltip": {
      "borderRadius": 6
    },

    "Pagination": {
      "borderRadius": 6
    },

    "Collapse": {
      "borderRadiusLG": 10
    },

    "Segmented": {
      "trackBg": "#EEF5F7",
      "itemSelectedBg": "#FFFFFF"
    },

    "Tag": {
      "borderRadiusSM": 999
    },

    "Checkbox": {
      "colorPrimary": "#18B7C9"
    },

    "Radio": {
      "colorPrimary": "#18B7C9"
    },

    "Switch": {
      "colorPrimary": "#18B7C9"
    },

    "Divider": {
      "colorSplit": "#E5EDF3"
    },

    "Descriptions": {
      "labelBg": "#F8FAFC"
    },

    "List": {
      "colorBorder": "#E5EDF3"
    }
  }
}
