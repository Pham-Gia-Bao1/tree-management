{
  "token": {
    "colorPrimary": "#7C3AED",
    "colorSuccess": "#22C55E",
    "colorWarning": "#F59E0B",
    "colorError": "#EF4444",

    "colorText": "#1F2937",
    "colorTextSecondary": "#6B7280",
    "colorTextTertiary": "#9CA3AF",

    "colorBgBase": "#FAFAFC",
    "colorBgLayout": "#F8F8FB",
    "colorBgContainer": "#FFFFFF",
    "colorBgElevated": "#FFFFFF",

    "colorBorder": "#E9E5F4",
    "colorBorderSecondary": "#F3F0FA",

    "borderRadius": 8,
    "borderRadiusSM": 6,
    "borderRadiusLG": 12,
    "borderRadiusXS": 4,

    "fontFamily": "\"Inter\", sans-serif",
    "fontSize": 14,

    "boxShadow": "0 2px 6px rgba(124,58,237,0.05)",
    "boxShadowSecondary": "0 8px 24px rgba(124,58,237,0.08)",
    "boxShadowTertiary": "0 1px 2px rgba(124,58,237,0.04)",

    "controlHeight": 40,
    "controlHeightSM": 32,
    "controlHeightLG": 44
  },

  "components": {
    "Card": {
      "borderRadiusLG": 12,
      "bodyPadding": 20
    },

    "Button": {
      "borderRadius": 8,
      "controlHeight": 40,
      "fontWeight": 600,
      "defaultShadow": "none",
      "primaryShadow": "none",

      "colorPrimary": "#7C3AED",
      "colorPrimaryHover": "#6D28D9",
      "colorPrimaryActive": "#5B21B6"
    },

    "Input": {
      "borderRadius": 8,
      "controlHeight": 40,

      "activeBorderColor": "#7C3AED",
      "hoverBorderColor": "#8B5CF6",
      "activeShadow": "0 0 0 3px rgba(124,58,237,.12)"
    },

    "InputNumber": {
      "borderRadius": 8,
      "activeBorderColor": "#7C3AED"
    },

    "Select": {
      "borderRadius": 8,
      "controlHeight": 40,

      "optionSelectedBg": "#F3E8FF",
      "optionActiveBg": "#FAF5FF",

      "activeBorderColor": "#7C3AED",
      "hoverBorderColor": "#8B5CF6"
    },

    "DatePicker": {
      "borderRadius": 8,
      "activeBorderColor": "#7C3AED"
    },

    "TimePicker": {
      "borderRadius": 8,
      "activeBorderColor": "#7C3AED"
    },

    "Table": {
      "borderRadiusLG": 12,
      "headerBg": "#FAFAFC",
      "rowHoverBg": "#FAF5FF",
      "borderColor": "#ECEAF5"
    },

    "Menu": {
      "itemHeight": 42,
      "itemBorderRadius": 8,

      "itemSelectedBg": "#F3E8FF",
      "itemSelectedColor": "#6D28D9",

      "itemHoverBg": "#FAF5FF",
      "itemHoverColor": "#6D28D9",

      "itemColor": "#6B7280"
    },

    "Modal": {
      "borderRadiusLG": 14
    },

    "Drawer": {
      "borderRadiusLG": 14
    },

    "Dropdown": {
      "borderRadiusLG": 12
    },

    "Popover": {
      "borderRadiusLG": 12
    },

    "Tooltip": {
      "borderRadius": 6
    },

    "Tag": {
      "borderRadiusSM": 999
    },

    "Pagination": {
      "borderRadius": 8
    },

    "Collapse": {
      "borderRadiusLG": 12
    },

    "Segmented": {
      "trackBg": "#F3F0FA"
    },

    "Tabs": {
      "itemSelectedColor": "#7C3AED",
      "itemActiveColor": "#7C3AED",
      "inkBarColor": "#7C3AED"
    },

    "Checkbox": {
      "colorPrimary": "#7C3AED"
    },

    "Radio": {
      "colorPrimary": "#7C3AED"
    },

    "Switch": {
      "colorPrimary": "#7C3AED"
    }
  }
}
